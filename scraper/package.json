{
  "name": "myra-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "T-04A headless browser load board scanner — bridge layer until DAT/Truckstop/123LB/Loadlink official API access lands",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
